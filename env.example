# ==========================================
# POLYMARKET COPYTRADING BOT - ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git - it contains sensitive credentials!

# ==========================================
# SQLITE CONFIGURATION
# ==========================================
# Local database file. It will be created automatically on first run.

SQLITE_DB_PATH=data/polymarket_bot.sqlite3

# ==========================================
# POLYMARKET CONFIGURATION
# ==========================================
# PK: Your Ethereum Private Key (NEVER share this!)
# Get from https://reveal.magic.link/polymarket or your Web3 wallet
PK=your-private-key-here

# POLY_FUNDER: Your Polymarket Proxy Address
# This is the address shown below your profile picture on Polymarket
POLY_FUNDER=your-polymarket-proxy-address-here

# CLOB_API_URL: Polymarket CLOB API endpoint
CLOB_API_URL=https://clob.polymarket.com

# POLY_CHAIN_ID: Polygon chain ID (137 for mainnet, 80002 for Amoy testnet)
POLY_CHAIN_ID=137

# ==========================================
# TRADER TO COPY
# ==========================================
# TRADER_WALLET: The wallet address of the trader you want to copy
# Find successful traders on Polymarket leaderboards
TRADER_WALLET=trader-wallet-address-to-copy

# ==========================================
# OPTIONAL: DATABASE TABLE NAMES
# ==========================================
# Customize these if you want different local table names
# TABLE_NAME_TRADES=historic_trades
# TABLE_NAME_POSITIONS=polymarket_positions

# ==========================================
# OPTIONAL: TELEGRAM NOTIFICATIONS
# ==========================================
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_CHAT_ID=your-telegram-chat-id
# TELEGRAM_TITLE_SUFFIX=_LOCAL

# ==========================================
# OPTIONAL: SIZING CONFIGURATION
# ==========================================
# STAKE_WHALE_PCT=0.001

# ==========================================
# OPTIONAL: POLLING / FRESHNESS GUARDS
# ==========================================
# HISTORY_POLL_INTERVAL_SECONDS=1
# POSITIONS_POLL_INTERVAL_SECONDS=300
# COPY_BUY_MAX_AGE_SECONDS=600

